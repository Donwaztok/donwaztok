{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "next/font/google": ["./node_modules/vinext/dist/shims/font-google"],
      "next/font/local": ["./node_modules/vinext/dist/shims/font-local"],
      "next/image": ["./node_modules/vinext/dist/shims/image"],
      "next/link": ["./node_modules/vinext/dist/shims/link"],
      "next/navigation": ["./node_modules/vinext/dist/shims/navigation"],
      "next/script": ["./node_modules/vinext/dist/shims/script"],
      "next/server": ["./node_modules/vinext/dist/shims/server"]
    }
  },
  "include": [
    "next-env.d.ts",
    "types/**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
